rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "subhu07web@gmail.com" ||
        request.auth.token.email == "subhu7web@gmail.com" ||
        request.auth.token.email == "daskajaldas780@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation functions
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidMenuItem(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 128;
    }

    function isValidOrder(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 256 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status is string && data.status.size() <= 64;
    }

    function isValidReservation(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 256 &&
             data.userPhone is string && data.userPhone.size() <= 32 &&
             data.date is string && data.date.size() <= 64 &&
             data.time is string && data.time.size() <= 64 &&
             data.guests is number && data.guests >= 1 &&
             data.tableNumber is string && data.tableNumber.size() <= 64 &&
             data.status is string && data.status.size() <= 64;
    }

    function isValidFeedback(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 256 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2048;
    }

    // Collections match blocks
    
    // (1) Users profile: Owner-only read/write
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && (request.method == 'delete' || isValidUser(incoming()));
    }

    // (2) Menu (Public Collection): Read for all, Write only for authenticated users (specifically admins)
    match /menu/{menuId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.method == 'delete' || isValidMenuItem(incoming()));
    }

    // (3) Private Collections (Orders & Reservations): Creator access only (plus administrative access)
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidOrder(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidOrder(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /reservations/{resId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidReservation(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidReservation(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // (4) Feedback Collection: Read for all, create/write for author
    match /feedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidFeedback(incoming());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidFeedback(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
